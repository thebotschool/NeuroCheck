#=================================================================#
#         ENVIRONMENT VARIABLES FOR CLIENT-SIDE (VITE)            #
#    These variables are prefixed with VITE_ and are PUBLIC.      #
#=================================================================#
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-public-anon-key

#=================================================================#
#        ENVIRONMENT VARIABLES FOR SERVER-SIDE (API/VERCEL)       #
#      These variables are SECRET and must NOT be committed.      #
#=================================================================#

# Supabase Admin Access
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend Email Service
RESEND_API_KEY=your-resend-api-key
MAIL_FROM=your@email.com

# Application Logic
SITE_URL=http://localhost:54321
TOKEN_TTL_HOURS=24
VITE_ADMIN_KEY=your-admin-key

# Dev bypass for /test
VITE_DEV_BYPASS_ENABLED=true
VITE_DEV_BYPASS_TOKEN=your-dev-bypass-token

ADMIN_KEY=your-admin-key

SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
